{
    "luci-theme-glass": {
        "description": "Grant access for luci-theme-glass",
        "read": {
            "uci": [ "glass" ],
            "file": {
                "/www/luci-static/glass/background/*": [ "list" ]
            },
            "ubus": {
                "network.interface": [ "dump" ],
                "network.device": [ "status" ]
            }
        },
        "write": {
            "uci": [ "glass" ]
        }
    }
}
