{
	"luci-app-argone-config": {
		"description": "Grant UCI access for luci-app-argone-config",
		"read": {
			"file": {
				"/www/luci-static/argone/background/*": [ "list" ]
			},
			"ubus": {
				"luci.argone": [ "avail", "remove", "rename" ]
			},
			"uci": [ "argone" ]
		},
		"write": {
			"file": {
				"/tmp/argone_background.tmp": [ "write" ]
			},
			"uci": [ "argone" ]
		}
	}
}
