#!/bin/sh

NAME="aliddns"
LOG_FILE="/var/log/${NAME}.log"

uci_get_by_name() {
	local ret
	ret="$(uci get "${NAME}.$1.$2" 2>/dev/null)"
	echo "${ret:-$3}"
}

uci_bool_by_name() {
	case "$(uci_get_by_name "$1" "$2")" in
		1 | on | true | yes | enabled) return 0 ;;
	esac
	return 1
}

# IPv4 address detection with multiple fallback sources
intelnetip() {
	local tmp_ip
	local sources="api-ipv4.ip.sb/ip v4.myip.la whatismyip.akamai.com ifconfig.me/ip api.ipify.org"
	for src in $sources; do
		tmp_ip="$(curl -sL --connect-timeout 5 -m 10 "https://${src}" 2>/dev/null | grep -oE '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$' | head -1)"
		[ -n "$tmp_ip" ] && break
	done
	echo -n "$tmp_ip"
}

# IPv6 address detection with multiple fallback sources
intelnetip6() {
	local tmp_ip6
	local sources="api-ipv6.ip.sb/ip v6.ident.me ip6only.me/api"
	for src in $sources; do
		tmp_ip6="$(curl -sL --connect-timeout 5 -m 10 "https://${src}" 2>/dev/null | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | head -1)"
		[ -n "$tmp_ip6" ] && break
	done
	echo -n "$tmp_ip6"
}

resolve2ip() {
	local domain="$1"
	local tmp_ip
	local dns_servers="ns1.alidns.com ns2.alidns.com 114.114.115.115 8.8.8.8"
	for dns in $dns_servers; do
		tmp_ip="$(nslookup "$domain" "$dns" 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | tail -n1)"
		[ -n "$tmp_ip" ] && break
	done
	echo -n "$tmp_ip"
}

resolve2ip6() {
	local domain="$1"
	local tmp_ip6
	local dns_servers="ns1.alidns.com ns2.alidns.com 2400:da00::6666"
	for dns in $dns_servers; do
		tmp_ip6="$(nslookup "$domain" "$dns" 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | tail -n1)"
		[ -n "$tmp_ip6" ] && break
	done
	echo -n "$tmp_ip6"
}

urlencode() {
	local str="$1"
	local encoded=""
	local i=0
	local c
	while [ $i -lt ${#str} ]; do
		c="${str:$i:1}"
		case "$c" in
			[a-zA-Z0-9._~-]) encoded="${encoded}${c}" ;;
			*) encoded="${encoded}$(printf '%%%02X' "'$c")" ;;
		esac
		i=$((i + 1))
	done
	echo -n "$encoded"
}

send_request() {
	local action="$1"
	local extra_params="$2"
	local args="AccessKeyId=${ak_id}&Action=${action}&Format=json&${extra_params}&Version=2015-01-09"
	local string_to_sign="GET&%2F&$(urlencode "$args")"
	local signature
	signature="$(printf '%s' "$string_to_sign" | openssl dgst -sha1 -hmac "${ak_sec}&" -binary | openssl base64 | tr -d '\n')"
	signature="$(urlencode "$signature")"
	curl -sSL --connect-timeout 10 -m 30 "http://alidns.aliyuncs.com/?${args}&Signature=${signature}"
}

get_recordid() {
	sed 's/RR/\n/g' | sed -n 's/.*RecordId[^0-9]*\([0-9]*\).*/\1\n/p' | sort -ru | sed '/^$/d'
}

check_aliddns() {
	echo "$DATE WAN-IP: ${ip}"
	if [ -z "$ip" ]; then
		echo "$DATE ERROR: Cannot get WAN-IP"
		return 0
	fi
	current_ip="$(resolve2ip "$dm_real")"
	[ -z "$current_ip" ] && rrid=''
	echo "$DATE DOMAIN-IP: ${current_ip}"
	if [ "$ip" = "$current_ip" ]; then
		echo "$DATE IP does not need update"
		return 0
	else
		echo "$DATE UPDATING..."
		return 1
	fi
}

check_aliddns6() {
	echo "$DATE WAN6-IP: ${ip6}"
	if [ -z "$ip6" ]; then
		echo "$DATE ERROR: Cannot get WAN6-IP"
		return 0
	fi
	current_ip6="$(resolve2ip6 "$dm_real")"
	[ -z "$current_ip6" ] && rrid6=''
	echo "$DATE DOMAIN-IP6: ${current_ip6}"
	if [ "$ip6" = "$current_ip6" ]; then
		echo "$DATE IPv6 does not need update"
		return 0
	else
		echo "$DATE UPDATING AAAA..."
		return 1
	fi
}

do_ddns_record() {
	if uci_bool_by_name base clean; then
		query_recordid | get_recordid | while read -r rr; do
			[ -n "$rr" ] || continue
			echo "$DATE Clean record $dm_show: $rr"
			del_record "$rr" >/dev/null 2>&1
			timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"
		done
		rrid=''
	fi
	[ -z "$rrid" ] && rrid="$(query_recordid | get_recordid)"
	if [ -z "$rrid" ]; then
		rrid="$(add_record | get_recordid)"
		echo "$DATE ADD record $rrid"
	else
		update_record "$rrid" >/dev/null 2>&1
		echo "$DATE UPDATE record $rrid"
	fi
	if [ -z "$rrid" ]; then
		echo "$DATE # ERROR: Please check config/time"
	else
		uci set aliddns.base.record_id="$rrid"
		uci commit aliddns
		echo "$DATE # UPDATED($ip)"
	fi
}

do_ddns_record6() {
	if uci_bool_by_name base clean; then
		query_recordid6 | get_recordid | while read -r rr; do
			[ -n "$rr" ] || continue
			echo "$DATE Clean record $dm_show: $rr"
			del_record "$rr" >/dev/null 2>&1
			timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"
		done
		rrid6=''
	fi
	[ -z "$rrid6" ] && rrid6="$(query_recordid6 | get_recordid)"
	if [ -z "$rrid6" ]; then
		rrid6="$(add_record6 | get_recordid)"
		echo "$DATE ADD record $rrid6"
	else
		update_record6 "$rrid6" >/dev/null 2>&1
		echo "$DATE UPDATE record $rrid6"
	fi
	if [ -z "$rrid6" ]; then
		echo "$DATE # ERROR: Please check config/time"
	else
		uci set aliddns.base.record_id6="$rrid6"
		uci commit aliddns
		echo "$DATE # UPDATED($ip6)"
	fi
}

query_recordid() {
	send_request "DescribeSubDomainRecords" "SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&SubDomain=${dm_escape}&Timestamp=${timestamp}&Type=A"
}

query_recordid6() {
	send_request "DescribeSubDomainRecords" "SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&SubDomain=${dm_escape}&Timestamp=${timestamp}&Type=AAAA"
}

update_record() {
	send_request "UpdateDomainRecord" "RR=${sub_dm_escape}&RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=A&Value=${ip}"
}

add_record() {
	send_request "AddDomainRecord&DomainName=${main_dm}" "RR=${sub_dm_escape}&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=A&Value=${ip}"
}

update_record6() {
	send_request "UpdateDomainRecord" "RR=${sub_dm_escape}&RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=AAAA&Value=${ip6_escape}"
}

add_record6() {
	send_request "AddDomainRecord&DomainName=${main_dm}" "RR=${sub_dm_escape}&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=AAAA&Value=${ip6_escape}"
}

del_record() {
	send_request "DeleteDomainRecord" "RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}"
}

clean_log() {
	local lines
	lines="$(wc -l < "$LOG_FILE" 2>/dev/null)" || lines=0
	if [ "$lines" -ge 500 ]; then
		tail -n 200 "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
		echo "$DATE Log trimmed (was $lines lines)"
	fi
}

# Pre-flight checks
command -v openssl >/dev/null 2>&1 || {
	echo "ERROR: openssl is required"
	exit 1
}

command -v curl >/dev/null 2>&1 || {
	echo "ERROR: curl is required"
	exit 1
}

# Load configuration
ipv4="$(uci_get_by_name base ipv4)"
ipv6="$(uci_get_by_name base ipv6)"
ak_id="$(uci_get_by_name base app_key)"
ak_sec="$(uci_get_by_name base app_secret)"
rrid="$(uci_get_by_name base record_id)"
rrid6="$(uci_get_by_name base record_id6)"
main_dm="$(uci_get_by_name base main_domain)"
sub_dm="$(uci_get_by_name base sub_domain)"

# Validate required config
if [ -z "$ak_id" ] || [ -z "$ak_sec" ] || [ -z "$main_dm" ]; then
	echo "ERROR: Missing required configuration (app_key, app_secret, main_domain)"
	exit 1
fi

# Build domain strings
if [ "$sub_dm" = "@" ] || [ -z "$sub_dm" ]; then
	dm_real="$main_dm"
else
	dm_real="${sub_dm}.${main_dm}"
fi
dm_show="${sub_dm}.${main_dm}"
dm_escape="$(urlencode "${sub_dm}.${main_dm}")"
sub_dm_escape="$(urlencode "$sub_dm")"

# Get WAN IP based on interface config
iface="$(uci_get_by_name base interface)"
if [ "$iface" = "internet" ] || [ -z "$iface" ]; then
	ip="$(intelnetip)"
else
	ip="$(ubus call "network.interface.${iface}" status 2>/dev/null | grep '"address"' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | head -1)"
fi

DATE="$(date '+%Y-%m-%d %H:%M:%S')"
timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"

# Process IPv4
if [ "$ipv4" = "1" ]; then
	check_aliddns || do_ddns_record
fi

# Get WAN6 IP based on interface6 config
iface6="$(uci_get_by_name base interface6)"
if [ "$iface6" = "internet" ] || [ -z "$iface6" ]; then
	ip6="$(intelnetip6)"
else
	ip6="$(ubus call "network.interface.${iface6}" status 2>/dev/null | grep '"address"' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | head -1)"
fi
ip6_escape="$(urlencode "$ip6")"

# Process IPv6
if [ "$ipv6" = "1" ]; then
	check_aliddns6 || do_ddns_record6
fi

clean_log
