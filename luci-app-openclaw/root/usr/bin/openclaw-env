#!/bin/sh
# ============================================================================
# openclaw-env — OpenClaw 环境安装管理脚本
# 用法: openclaw-env setup | check | upgrade | node
# 环境变量: OC_VERSION — 指定安装版本，不设置则安装稳定测试版
# ============================================================================

# ── 版本与路径常量 ─────────────────────────────────────────────────────────
NODE_VERSION="22.16.0"
OC_TESTED_VERSION="2026.3.13"
OC_VERSION="${OC_VERSION:-}"

NODE_BASE="/opt/openclaw/node"
OC_GLOBAL="/opt/openclaw/global"
OC_DATA="/opt/openclaw/data"
NODE_BIN="${NODE_BASE}/bin/node"
NPM_BIN="${NODE_BASE}/bin/npm"

# 下载镜像
NODE_MUSL_CN="https://npmmirror.com/mirrors/node"
NODE_MUSL_UNOFFICIAL="https://unofficial-builds.nodejs.org/download/release"
NODE_SELF_HOST="https://github.com/kenzok8/luci-app-openclaw/releases/download/node-bins"
ALPINE_MIRROR="https://mirrors.aliyun.com/alpine/v3.21/main"
ALPINE_CDN="https://dl-cdn.alpinelinux.org/alpine/v3.21/main"

export PATH="${NODE_BASE}/bin:${OC_GLOBAL}/bin:$PATH"

# ── 日志工具 ───────────────────────────────────────────────────────────────
log_ok()   { echo "  [✓] $*"; }
log_warn() { echo "  [!] $*"; }
log_err()  { echo "  [✗] $*"; }
log_step() { echo ""; echo "=== $* ==="; }

# ── OverlayFS 修复（iStoreOS Docker /opt 冲突）──────────────────────────────
_fix_opt() {
	mkdir -p /opt/openclaw/.probe 2>/dev/null && { rmdir /opt/openclaw/.probe 2>/dev/null; return 0; }
	[ -d /overlay/upper/opt ] && mkdir -p /overlay/upper/opt/openclaw 2>/dev/null && \
		mount --bind /overlay/upper/opt /opt 2>/dev/null && return 0
	return 1
}
_fix_opt

# ── 基础工具 ───────────────────────────────────────────────────────────────
ensure_dir() { [ -d "$1" ] && return 0; mkdir -p "$1" 2>/dev/null || { log_err "无法创建目录: $1"; return 1; }; }

# 检查路径可用空间，不足则警告（不阻断）
# 用 tail -1 + $(NF-2) 兼容 BusyBox df 长设备名换行的输出格式
_df_avail() {
	# 路径不存在则尝试上级直到根
	local p="$1"
	while [ -n "$p" ] && [ "$p" != "/" ]; do
		[ -e "$p" ] && break
		p="${p%/*}"
	done
	[ -z "$p" ] && p="/"
	df -m "$p" 2>/dev/null | tail -1 | awk '{print $(NF-2)}'
}

check_space() {
	local path="$1" need_mb="$2" label="$3"
	local avail
	avail=$(_df_avail "$path")
	[ -z "$avail" ] && return 0
	if [ "$avail" -lt "$need_mb" ]; then
		log_warn "${label} 可用空间不足：${avail}MB < ${need_mb}MB 建议值，安装可能失败"
	else
		log_ok "${label} 可用空间：${avail}MB"
	fi
}

# 统一下载：BusyBox wget 优先，curl 备用
_download() {
	local url="$1" out="$2"
	if command -v wget >/dev/null 2>&1; then
		wget -q --no-check-certificate -O "$out" "$url" 2>/dev/null
	elif command -v curl >/dev/null 2>&1; then
		curl -fsSL --connect-timeout 15 --max-time 120 -o "$out" "$url" 2>/dev/null
	else
		log_err "没有可用的下载工具 (wget/curl)"; return 1
	fi
}

# 尝试多个镜像，返回第一个成功的文件
_download_first() {
	local out="$1"; shift
	for url in "$@"; do
		[ -z "$url" ] && continue
		if _download "$url" "$out"; then
			local sz; sz=$(wc -c < "$out" 2>/dev/null || echo 0)
			[ "$sz" -gt 10000 ] && return 0
		fi
		rm -f "$out"
	done
	return 1
}

# ── 架构检测 ───────────────────────────────────────────────────────────────
detect_arch() {
	case "$(uname -m)" in
		x86_64)  echo "linux-x64" ;;
		aarch64) echo "linux-arm64" ;;
		*) log_err "不支持的架构: $(uname -m)"; exit 1 ;;
	esac
}

detect_libc() {
	[ -f /etc/openwrt_release ] && echo "musl" && return
	for f in /lib/ld-musl-*.so.1; do [ -f "$f" ] && echo "musl" && return; done
	echo "glibc"
}

# ── 查找 openclaw 入口文件 ─────────────────────────────────────────────────
find_oc_entry() {
	local d
	for d in \
		"${OC_GLOBAL}/lib/node_modules/openclaw" \
		"${OC_GLOBAL}/node_modules/openclaw" \
		"${NODE_BASE}/lib/node_modules/openclaw"; do
		[ -f "${d}/openclaw.mjs" ] && echo "${d}/openclaw.mjs" && return
		[ -f "${d}/dist/cli.js"  ] && echo "${d}/dist/cli.js"  && return
	done
	# pnpm 版本化路径 (如 global/5/node_modules/openclaw)
	for d in "${OC_GLOBAL}"/*/node_modules/openclaw; do
		[ -f "${d}/openclaw.mjs" ] && echo "${d}/openclaw.mjs" && return
		[ -f "${d}/dist/cli.js"  ] && echo "${d}/dist/cli.js"  && return
	done
}

# ── 安装 git（npm 依赖） ───────────────────────────────────────────────────
# 策略：opkg → 从 Alpine APK 提取二进制（Alpine 与 ImmortalWrt 同为 musl，ABI 兼容）
# Alpine APK 有签名头，BusyBox tar 需要跳过才能解压
_extract_apk_file() {
	# 用法: _extract_apk_file <apk文件> <目标目录> <要找的文件名模式>
	# Alpine APK = 签名段 + gzip tar，BusyBox tar 可能停在签名段
	# 先直接解压，失败则用 dd 跳过签名（签名段 < 4096 字节）
	local apk="$1" dest="$2" pattern="$3"
	ensure_dir "$dest"
	( cd "$dest" && tar xzf "$apk" 2>/dev/null ) || true
	local found; found=$(find "$dest" -name "$pattern" | head -1)
	[ -n "$found" ] && echo "$found" && return 0

	# BusyBox tar 停在签名段，用 dd 逐步跳过
	local offset ex
	for offset in 512 1024 2048 4096; do
		ex="${dest}/ex${offset}"
		ensure_dir "$ex"
		dd if="$apk" bs=1 skip=$offset 2>/dev/null | tar xzf - -C "$ex" 2>/dev/null || true
		found=$(find "$ex" -name "$pattern" | head -1)
		[ -n "$found" ] && echo "$found" && return 0
	done
	return 1
}

install_git() {
	command -v git >/dev/null 2>&1 && return 0
	log_warn "未检测到 git，正在尝试安装..."

	# 1) opkg
	opkg install git git-http 2>/dev/null | tail -2 || true
	command -v git >/dev/null 2>&1 && { log_ok "git 已通过 opkg 安装"; return 0; }

	# 2) 从 Alpine APK 提取 git 二进制
	local arch
	case "$(uname -m)" in
		x86_64)  arch="x86_64" ;;
		aarch64) arch="aarch64" ;;
		*) log_warn "无法为此架构安装 git"; return 1 ;;
	esac

	local tmp="/tmp/oc-git-$$"
	ensure_dir "$tmp" || return 1
	local pkg="git-2.47.3-r0.apk"

	log_warn "尝试从 Alpine 镜像提取 git..."
	if _download_first "$tmp/git.apk" \
		"${ALPINE_MIRROR}/${arch}/${pkg}" \
		"${ALPINE_CDN}/${arch}/${pkg}"; then

		local git_bin
		git_bin=$(_extract_apk_file "$tmp/git.apk" "$tmp/extracted" "git")
		# 过滤掉目录，只要可执行文件
		[ -n "$git_bin" ] && [ ! -d "$git_bin" ] || \
			git_bin=$(find "$tmp/extracted" -name "git" -type f | head -1)

		if [ -n "$git_bin" ] && [ -f "$git_bin" ]; then
			# 直接安装到系统路径（安装后通过 _GIT_INSTALLED 标记，用完清理）
			# 这是最可靠的方式——npm spawn 继承完整系统 PATH 和 libexec
			cp "$git_bin" /usr/bin/git && chmod 755 /usr/bin/git
			_GIT_INSTALLED_SYSTEM=1

			# 安装 git-core（含 git-remote-https）到系统路径
			# Alpine 固定路径: usr/libexec/git-core（不用 find，避免取到 usr/share/git-core）
			local core_src="$tmp/extracted/usr/libexec/git-core"
			if [ -d "$core_src" ] && [ -f "$core_src/git-remote-https" ]; then
				mkdir -p /usr/libexec
				cp -r "$core_src" /usr/libexec/git-core
				chmod 755 /usr/libexec/git-core/* 2>/dev/null || true
			fi
			rm -rf "$tmp"

			opkg install libpcre2 2>/dev/null | tail -1 || true

			if /usr/bin/git --version >/dev/null 2>&1; then
				log_ok "git 可用: $(/usr/bin/git --version 2>/dev/null)"
				return 0
			else
				log_warn "git 二进制无法运行"
				rm -f /usr/bin/git; rm -rf /usr/libexec/git-core
				_GIT_INSTALLED_SYSTEM=0
			fi
		fi
	fi

	rm -rf "$tmp"
	log_warn "git 安装失败，npm 将因 git 依赖报错"
	return 1
}

_GIT_CFG=""  # 临时 git 配置文件路径

setup_git_config() {
	# 将 SSH git URL 重写为 HTTPS（OpenWrt 无 SSH 密钥，GitHub SSH 端口常被封）
	_GIT_CFG="/tmp/oc-gitcfg-$$"
	cat > "$_GIT_CFG" << 'EOF'
[url "https://github.com/"]
    insteadOf = ssh://git@github.com/
    insteadOf = git@github.com:
    insteadOf = git://github.com/
EOF
	export GIT_CONFIG_GLOBAL="$_GIT_CFG"
}

_GIT_INSTALLED_SYSTEM=0
cleanup_git() {
	if [ "${_GIT_INSTALLED_SYSTEM:-0}" = "1" ]; then
		rm -f /usr/bin/git
		rm -rf /usr/libexec/git-core 2>/dev/null || true
		_GIT_INSTALLED_SYSTEM=0
	fi
	[ -n "$_GIT_CFG" ] && rm -f "$_GIT_CFG" && _GIT_CFG="" && unset GIT_CONFIG_GLOBAL
	log_ok "已清理临时 git"
}

# ── 安装 libstdc++（Node.js 运行依赖）─────────────────────────────────────
ensure_node_deps() {
	[ -e /usr/lib/libstdc++.so.6 ] || [ -e /lib/libstdc++.so.6 ] && return 0

	log_warn "缺少 libstdc++.so.6，尝试安装..."
	opkg install libstdcpp 2>/dev/null | tail -2 || true
	[ -e /usr/lib/libstdc++.so.6 ] || [ -e /lib/libstdc++.so.6 ] && return 0

	# 从 Alpine 提取
	local arch; case "$(uname -m)" in x86_64) arch="x86_64";; aarch64) arch="aarch64";; *) return 1;; esac
	local tmp="/tmp/oc-libstdc-$$"; ensure_dir "$tmp" || return 1
	local pkg="libstdc++-14.2.0-r4.apk"

	_download_first "$tmp/lib.apk" \
		"${ALPINE_MIRROR}/${arch}/${pkg}" \
		"${ALPINE_CDN}/${arch}/${pkg}" || { rm -rf "$tmp"; return 1; }

	( cd "$tmp" && tar xzf lib.apk 2>/dev/null ) || true

	local so; so=$(find "$tmp" -name "libstdc++.so.6.*" | head -1)
	if [ -n "$so" ]; then
		cp "$so" /usr/lib/
		ln -sf "/usr/lib/$(basename "$so")" /usr/lib/libstdc++.so.6
		ldconfig 2>/dev/null || true
		log_ok "libstdc++.so.6 安装成功"
		rm -rf "$tmp"; return 0
	fi

	rm -rf "$tmp"
	log_err "libstdc++ 安装失败"
	return 1
}

# ── 安装 Node.js ───────────────────────────────────────────────────────────
install_node() {
	local node_ver="${1:-$NODE_VERSION}"
	local node_arch; node_arch=$(detect_arch)
	local libc; libc=$(detect_libc)

	# 已安装且版本匹配则跳过
	if [ -x "$NODE_BIN" ]; then
		local cur; cur=$("$NODE_BIN" --version 2>/dev/null | sed 's/^v//')
		if [ "$cur" = "$node_ver" ] || [ "$(echo "$cur" | cut -d. -f1)" = "$(echo "$node_ver" | cut -d. -f1)" ]; then
			log_ok "Node.js v${cur} 已安装，跳过下载"
			return 0
		fi
		log_warn "当前 Node.js v${cur}，将更新到 v${node_ver}"
	fi

	log_step "下载 Node.js v${node_ver} (${node_arch}, ${libc})"

	local tarball="node-v${node_ver}-${node_arch}-musl.tar.gz"
	local tmp_file="/tmp/oc-node-$$.tar.gz"

	if [ "$libc" = "musl" ]; then
		if [ "$node_arch" = "linux-arm64" ]; then
			_download_first "$tmp_file" \
				"${NODE_SELF_HOST}/${tarball}" \
				"${NODE_MUSL_UNOFFICIAL}/v${node_ver}/${tarball}" || \
				{ log_err "Node.js 下载失败"; exit 1; }
		else
			_download_first "$tmp_file" \
				"${NODE_MUSL_CN}/v${node_ver}/${tarball}" \
				"${NODE_MUSL_UNOFFICIAL}/v${node_ver}/${tarball}" \
				"${NODE_SELF_HOST}/${tarball}" || \
				{ log_err "Node.js 下载失败"; exit 1; }
		fi
	else
		local glibc_tarball="node-v${node_ver}-${node_arch}.tar.gz"
		_download_first "$tmp_file" \
			"${NODE_MUSL_CN}/v${node_ver}/${glibc_tarball}" \
			"https://nodejs.org/dist/v${node_ver}/${glibc_tarball}" || \
			{ log_err "Node.js 下载失败"; exit 1; }
	fi

	echo "  正在解压..."
	rm -rf "$NODE_BASE" 2>/dev/null
	[ -d /overlay/upper ] && rm -rf "/overlay/upper${NODE_BASE}" 2>/dev/null
	ensure_dir "$NODE_BASE"

	# 解压（BusyBox tar 兼容）
	if ! tar --strip-components=1 -zxf "$tmp_file" -C "$NODE_BASE" 2>/dev/null; then
		local xtmp="/tmp/oc-node-extract-$$"
		ensure_dir "$xtmp"
		tar zxf "$tmp_file" -C "$xtmp" 2>/dev/null || { log_err "解压失败"; rm -f "$tmp_file"; exit 1; }
		local topdir; topdir=$(ls "$xtmp" | head -1)
		[ -d "$xtmp/$topdir" ] && mv "$xtmp/$topdir"/* "$NODE_BASE"/ 2>/dev/null
		rm -rf "$xtmp"
	fi
	rm -f "$tmp_file"

	ensure_node_deps || exit 1

	"$NODE_BIN" --version >/dev/null 2>&1 || { log_err "Node.js 安装验证失败"; exit 1; }
	log_ok "Node.js $("$NODE_BIN" --version) 安装成功"
}

# ── 安装 OpenClaw ──────────────────────────────────────────────────────────

# npm 安装辅助：_npm_install_pkg <pkg> <registry> <npm_tmp> <install_flags> <attempt>
_npm_install_pkg() {
	local pkg="$1" registry="$2" npm_tmp="$3" flags="$4" attempt="$5"
	log_warn "安装尝试 ${attempt}：${registry}"
	ensure_dir "${npm_tmp}/cache"
	ensure_dir "${npm_tmp}/logs"
	"$NPM_BIN" install -g "$pkg" \
		--prefix="$OC_GLOBAL" \
		$flags \
		--cache="${npm_tmp}/cache" \
		--logs-dir="${npm_tmp}/logs" \
		--registry="$registry" \
		--fetch-timeout=90000 \
		--fetch-retry-mintimeout=5000 \
		--fetch-retry-maxtimeout=30000 \
		--fetch-retries=2 \
		--prefer-offline=false \
		--no-fund --no-audit 2>&1 | tail -20
}

_finish_openclaw_install() {
	local npm_tmp="$1"
	rm -rf "$npm_tmp" 2>/dev/null || true
	cleanup_git
	local ver; ver=$("$NODE_BIN" "$(find_oc_entry)" --version 2>/dev/null | tr -d '[:space:]')
	log_ok "OpenClaw v${ver} 安装成功"
}

install_openclaw() {
	local oc_pkg="openclaw"
	local libc; libc=$(detect_libc)
	local install_flags=""
	[ "$libc" = "musl" ] && install_flags="--ignore-scripts"

	if [ -n "$OC_VERSION" ]; then
		oc_pkg="openclaw@${OC_VERSION}"
		log_ok "指定版本: v${OC_VERSION}"
	else
		log_ok "安装最新版"
	fi

	# 确保 git 可用（openclaw 依赖 ssh://git@github.com/ URL）
	install_git
	setup_git_config  # SSH → HTTPS 重写（无需 SSH 密钥）

	log_step "安装 OpenClaw"
	ensure_dir "$OC_GLOBAL"

	# npm cache 和 logs 全部放到 tmpfs，避免根分区 ENOSPC
	[ -d /root/.npm ] && rm -rf /root/.npm 2>/dev/null && log_ok "已清理旧 npm 缓存"
	# 低内存设备 /tmp 可能只有 50-100MB，不够放 npm 缓存；改到 /opt 同盘
	local npm_tmp
	local tmp_avail; tmp_avail=$(_df_avail /tmp)
	if [ -n "$tmp_avail" ] && [ "$tmp_avail" -ge 200 ]; then
		npm_tmp="/tmp/oc-npm-$$"
	else
		npm_tmp="${OC_DATA}/.npm-$$"
		log_warn "/tmp 空间不足（${tmp_avail:-?}MB），npm 缓存改到 ${npm_tmp}"
	fi

	# 第一次：npmmirror（国内最快）
	_npm_install_pkg "$oc_pkg" "https://registry.npmmirror.com" "$npm_tmp" "$install_flags" 1

	if [ -n "$(find_oc_entry)" ]; then
		_finish_openclaw_install "$npm_tmp"
		return 0
	fi

	# 第二次：清理损坏缓存，切换到 npmjs.org 官方源
	log_warn "npmmirror 安装失败，清理缓存并切换到官方源重试..."
	rm -rf "${OC_GLOBAL}/lib/node_modules/openclaw" 2>/dev/null || true
	rm -rf "${npm_tmp}/cache" 2>/dev/null || true

	_npm_install_pkg "$oc_pkg" "https://registry.npmjs.org" "$npm_tmp" "$install_flags" 2

	if [ -n "$(find_oc_entry)" ]; then
		_finish_openclaw_install "$npm_tmp"
		return 0
	fi

	rm -rf "$npm_tmp" 2>/dev/null || true
	cleanup_git
	log_err "OpenClaw 安装失败（已尝试 npmmirror 和 npmjs.org）"
	log_err "请检查网络连接或磁盘空间后重试"
	exit 1
}

# ── 初始化 OpenClaw 配置 ───────────────────────────────────────────────────
init_openclaw() {
	log_step "初始化 OpenClaw"

	ensure_dir "${OC_DATA}/.openclaw"
	local oc_entry; oc_entry=$(find_oc_entry)
	[ -z "$oc_entry" ] && return 0

	# onboard
	HOME="$OC_DATA" OPENCLAW_HOME="$OC_DATA" \
	OPENCLAW_STATE_DIR="${OC_DATA}/.openclaw" \
	OPENCLAW_CONFIG_PATH="${OC_DATA}/.openclaw/openclaw.json" \
	"$NODE_BIN" "$oc_entry" onboard --non-interactive --accept-risk --tools-profile coding 2>/dev/null || true

	# OpenWrt 适配：写入推荐配置
	local cfg="${OC_DATA}/.openclaw/openclaw.json"
	if [ -f "$cfg" ]; then
		local tok
		tok=$(head -c 24 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 48)
		for kv in \
			"gateway.port=18789" \
			"gateway.bind=lan" \
			"gateway.mode=local" \
			"gateway.auth.mode=token" \
			"gateway.auth.token=${tok}" \
			"gateway.controlUi.allowInsecureAuth=true" \
			"gateway.controlUi.dangerouslyDisableDeviceAuth=true" \
			"gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback=true" \
			"gateway.tailscale.mode=off" \
			"acp.dispatch.enabled=false" \
			"tools.profile=coding"; do
			local k="${kv%%=*}" v="${kv#*=}"
			_JS_KEY="$k" _JS_VAL="$v" "$NODE_BIN" -e "
const fs=require('fs'),cfg=process.env._JS_KEY.split('.'),v=process.env._JS_VAL;
let d={};try{d=JSON.parse(fs.readFileSync('${cfg}','utf8'));}catch(e){}
let o=d;for(let i=0;i<cfg.length-1;i++){if(!o[cfg[i]]||typeof o[cfg[i]]!=='object')o[cfg[i]]={};o=o[cfg[i]];}
try{o[cfg[cfg.length-1]]=JSON.parse(v);}catch(e){o[cfg[cfg.length-1]]=v;}
fs.writeFileSync('${cfg}',JSON.stringify(d,null,2));
" 2>/dev/null
		done
		# 同步 token 到 UCI
		uci set openclaw.main.token="$tok" 2>/dev/null || true
		uci commit openclaw 2>/dev/null || true
		log_ok "配置初始化完成"
	fi

	chown -R openclaw:openclaw "$OC_DATA" "$OC_GLOBAL" "$NODE_BASE" 2>/dev/null || true
}

# ── 命令：setup ────────────────────────────────────────────────────────────
cmd_setup() {
	check_space /opt 200 "安装目录(/opt)"
	check_space /tmp 300 "临时目录(/tmp)"

	# 已安装则提示并退出
	if [ -x "$NODE_BIN" ] && [ -n "$(find_oc_entry)" ]; then
		echo "╔══════════════════════════════════════════════════════════════╗"
		echo "║   [!]  OpenClaw 已安装，如需重装请先卸载                     ║"
		echo "╚══════════════════════════════════════════════════════════════╝"
		echo "  Node.js:  $("$NODE_BIN" --version 2>/dev/null)"
		echo "  如需升级: openclaw-env upgrade"
		exit 0
	fi

	local oc_ver_display="${OC_VERSION:-最新版}"
	[ -n "$OC_VERSION" ] && oc_ver_display="v${OC_VERSION} (稳定版)"

	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║                kenzok8  OpenClaw 环境安装                    ║"
	echo "╚══════════════════════════════════════════════════════════════╝"
	echo "  架构:      $(uname -m)"
	echo "  Node:      v${NODE_VERSION}"
	echo "  OpenClaw:  ${oc_ver_display}"
	echo "  安装路径:  ${NODE_BASE}"
	echo "  数据路径:  ${OC_DATA}"
	echo ""

	install_node "$NODE_VERSION"
	install_openclaw
	init_openclaw

	echo ""
	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║  ✅ 安装完成！请在 LuCI → 服务 → OpenClaw 中启用服务         ║"
	echo "╚══════════════════════════════════════════════════════════════╝"
}

# ── 命令：check ────────────────────────────────────────────────────────────
cmd_check() {
	echo "=== OpenClaw 环境检查 ==="
	echo ""
	if [ -x "$NODE_BIN" ]; then
		echo "  Node.js:  $("$NODE_BIN" --version 2>/dev/null)"
	else
		echo "  Node.js:  未安装"
	fi

	local oc_entry; oc_entry=$(find_oc_entry)
	if [ -n "$oc_entry" ] && [ -x "$NODE_BIN" ]; then
		echo "  OpenClaw: v$("$NODE_BIN" "$oc_entry" --version 2>/dev/null | tr -d '[:space:]')"
	else
		echo "  OpenClaw: 未安装"
	fi

	[ -f "${OC_DATA}/.openclaw/openclaw.json" ] && \
		echo "  配置:     ${OC_DATA}/.openclaw/openclaw.json (存在)" || \
		echo "  配置:     未初始化"

	echo "  磁盘:     $(du -sh /opt/openclaw 2>/dev/null | awk '{print $1}' || echo 'N/A')"
	echo "  C库:      $(detect_libc)"
	echo "  git:      $(command -v git >/dev/null 2>&1 && git --version 2>/dev/null || echo '未安装')"
}

# ── 命令：upgrade ──────────────────────────────────────────────────────────
cmd_upgrade() {
	[ -x "$NODE_BIN" ] || { log_err "Node.js 未安装，请先运行: openclaw-env setup"; exit 1; }

	local libc; libc=$(detect_libc)
	local install_flags=""
	[ "$libc" = "musl" ] && install_flags="--ignore-scripts"

	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║                kenzok8  OpenClaw 升级                        ║"
	echo "╚══════════════════════════════════════════════════════════════╝"

	install_git
	setup_git_config

	log_step "升级 OpenClaw"
	local npm_tmp; local tmp_avail; tmp_avail=$(_df_avail /tmp)
	if [ -n "$tmp_avail" ] && [ "$tmp_avail" -ge 200 ]; then
		npm_tmp="/tmp/oc-npm-$$"
	else
		npm_tmp="${OC_DATA}/.npm-$$"
	fi

	_npm_install_pkg "openclaw@latest" "https://registry.npmmirror.com" "$npm_tmp" "$install_flags" 1

	# 验证，失败则切换官方源
	if [ -z "$(find_oc_entry)" ]; then
		log_warn "切换到官方源重试..."
		rm -rf "${npm_tmp}/cache" 2>/dev/null || true
		_npm_install_pkg "openclaw@latest" "https://registry.npmjs.org" "$npm_tmp" "$install_flags" 2
	fi

	rm -rf "$npm_tmp" 2>/dev/null || true
	cleanup_git

	local ver; ver=$("$NODE_BIN" "$(find_oc_entry)" --version 2>/dev/null | tr -d '[:space:]')
	log_ok "当前版本: v${ver}"
	echo ""
	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║  ✅ 升级完成！                                               ║"
	echo "╚══════════════════════════════════════════════════════════════╝"
}

# ── 命令：node（仅更新 Node.js）───────────────────────────────────────────
cmd_node() {
	install_node "$NODE_VERSION"
}

# ── 命令：factory-reset ────────────────────────────────────────────────────
cmd_factory_reset() {
	local cfg="${OC_DATA}/.openclaw/openclaw.json"
	log_warn "恢复出厂设置..."

	/etc/init.d/openclaw stop >/dev/null 2>&1 || true; sleep 2

	# 备份
	if [ -f "$cfg" ]; then
		local bk="${OC_DATA}/.openclaw/backups/openclaw_$(date +%Y%m%d_%H%M%S).json"
		ensure_dir "$(dirname "$bk")"
		cp "$cfg" "$bk" && log_ok "配置已备份: $bk"
	fi

	# 重置
	rm -f "$cfg" "${cfg}.bak" 2>/dev/null; echo '{}' > "$cfg"
	chown openclaw:openclaw "$cfg" 2>/dev/null || true

	init_openclaw
	/etc/init.d/openclaw start >/dev/null 2>&1 &
	log_ok "出厂设置已恢复，Gateway 重启中..."
}

# ── 命令：setup-offline ────────────────────────────────────────────────────
cmd_setup_offline() {
	local dir="${1:-/tmp/openclaw-offline}"
	[ -d "$dir" ] || { log_err "离线目录不存在: $dir"; exit 1; }

	if [ -x "$NODE_BIN" ] && [ -n "$(find_oc_entry)" ]; then
		log_warn "OpenClaw 已安装，如需重装请先卸载"; exit 0
	fi

	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║                kenzok8  OpenClaw 离线安装                    ║"
	echo "╚══════════════════════════════════════════════════════════════╝"

	# Node.js
	log_step "安装 Node.js (离线)"
	local node_pkg=""
	[ -f "$dir/node.tar.gz" ] && node_pkg="$dir/node.tar.gz"
	[ -z "$node_pkg" ] && [ -f "$dir/node.tar.xz" ] && node_pkg="$dir/node.tar.xz"
	[ -n "$node_pkg" ] || { log_err "未找到 Node.js 离线包"; exit 1; }

	rm -rf "$NODE_BASE" 2>/dev/null
	ensure_dir "$NODE_BASE"
	tar --strip-components=1 -zxf "$node_pkg" -C "$NODE_BASE" 2>/dev/null || \
		{ log_err "Node.js 解压失败"; exit 1; }
	ensure_node_deps || exit 1
	log_ok "Node.js $("$NODE_BIN" --version 2>/dev/null) 安装成功"

	# openclaw tarball
	log_step "安装 OpenClaw (离线)"
	local oc_pkg=""
	[ -f "$dir/openclaw.tgz" ] && oc_pkg="$dir/openclaw.tgz"
	[ -z "$oc_pkg" ] && oc_pkg=$(ls "$dir"/openclaw-*.tgz 2>/dev/null | head -1)
	[ -n "$oc_pkg" ] || { log_err "未找到 openclaw 离线包"; exit 1; }

	ensure_dir "$OC_GLOBAL"
	local libc; libc=$(detect_libc)
	local flags=""; [ "$libc" = "musl" ] && flags="--ignore-scripts"
	"$NPM_BIN" install -g "$oc_pkg" --prefix="$OC_GLOBAL" $flags --no-fund --no-audit 2>&1 | tail -10

	[ -n "$(find_oc_entry)" ] || { log_err "离线安装验证失败"; exit 1; }
	log_ok "OpenClaw 离线安装成功"

	init_openclaw

	echo ""
	echo "╔══════════════════════════════════════════════════════════════╗"
	echo "║  ✅ 离线安装完成！                                           ║"
	echo "╚══════════════════════════════════════════════════════════════╝"
}

# ── 主入口 ─────────────────────────────────────────────────────────────────
case "${1:-}" in
	setup)         cmd_setup ;;
	check)         cmd_check ;;
	upgrade)       cmd_upgrade ;;
	node)          cmd_node ;;
	factory-reset) cmd_factory_reset ;;
	setup-offline) cmd_setup_offline "${2:-}" ;;
	*)
		echo "用法: openclaw-env <命令>"
		echo ""
		echo "命令:"
		echo "  setup          完整安装 (Node.js + OpenClaw)"
		echo "  check          检查环境状态"
		echo "  upgrade        升级 OpenClaw 到最新版"
		echo "  node           仅更新 Node.js"
		echo "  factory-reset  恢复出厂设置"
		echo "  setup-offline  从本地文件安装"
		echo ""
		echo "环境变量:"
		echo "  OC_VERSION     指定安装版本 (如 2026.3.13)"
		exit 1
		;;
esac
